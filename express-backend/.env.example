# 数据库连接（与 Java 端共用同一个 MySQL）
DATABASE_URL="mysql://root:password@localhost:3306/pixelreel"

# 服务端口
PORT=18889

# JWT 鉴权
JWT_SECRET=your-jwt-secret-here
JWT_USERNAME=zaynzhu
JWT_PASSWORD=123456
# 是否启用 JWT 鉴权（true/false，默认 false，与 Java 端当前行为一致）
AUTH_ENABLED=false

# TMDB
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# OMDb
OMDB_API_KEY=
OMDB_BASE_URL=https://www.omdbapi.com

# Trakt
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_BASE_URL=https://api.trakt.tv
TRAKT_REDIRECT_URI=http://localhost:18889/api/trakt/callback

# 豆瓣
DOUBAN_BASE_URL=https://movie.douban.com
DOUBAN_COOKIE=

# RAWG
RAWG_API_KEY=
RAWG_BASE_URL=https://api.rawg.io/api

# Steam Web API
